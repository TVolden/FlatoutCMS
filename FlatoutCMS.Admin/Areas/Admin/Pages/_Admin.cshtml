<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@(ViewData["Title"] ?? "FlatoutCMS Admin")</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-stone-50 text-stone-900">

    <header class="flex items-center gap-6 px-4 h-11 bg-stone-900 text-stone-200 text-sm">
        <a href="/Admin" class="font-semibold text-white tracking-tight">FlatoutCMS</a>
        <nav class="flex gap-4">
            <a href="/Admin" class="text-stone-400 hover:text-white transition-colors">Dashboard</a>
            <a href="/Admin/Editor" class="text-stone-400 hover:text-white transition-colors">Editor</a>
        </nav>
        @if (Context.User?.Identity?.IsAuthenticated == true)
        {
            <div class="ml-auto flex items-center gap-3 text-stone-400 text-xs">
                <span>@Context.User.Identity.Name</span>
                <form method="post" action="/Admin/Logout">
                    <button type="submit" class="border border-stone-600 px-2.5 py-1 rounded hover:border-stone-400 hover:text-stone-200 transition-colors cursor-pointer">
                        Sign out
                    </button>
                </form>
            </div>
        }
    </header>

    @RenderBody()

    @RenderSection("Scripts", required: false)
</body>
</html>
